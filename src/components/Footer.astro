---
import SocialLinks from "./SocialLinks.astro";

const today = new Date();
---

<footer>
  <div class="footer-content">
    <div class="footer-section">
      <h3>Alan Zheng</h3>
      <p>
        Software Engineer specializing in cloud infrastructure, AI, and
        decentralized technologies.
      </p>
      <div class="footer-links">
        <a href="/about">About</a>
        <a href="/blog">Blog</a>
        <a href="/contact">Contact</a>
      </div>
    </div>

    <div class="footer-section">
      <h3>Technologies</h3>
      <div class="tech-list">
        <span>☁️ Cloud Infrastructure</span>
        <span>🤖 AI & Machine Learning</span>
        <span>🌐 Web3 & IPFS</span>
        <span>⚡ Full-Stack Development</span>
      </div>
    </div>

    <div class="footer-section">
      <h3>Connect</h3>
      <div class="footer-social">
        <SocialLinks />
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-content">
      <p>&copy; {today.getFullYear()} Alan Zheng. All rights reserved.</p>
      <p class="footer-tagline">Building the future with code</p>
    </div>
  </div>
</footer>
<style>
  footer {
    background: rgba(15, 15, 35, 0.95);
    backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: 4rem;
    position: relative;
    overflow: hidden;
  }

  footer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(
        circle at 20% 80%,
        rgba(99, 102, 241, 0.1) 0%,
        transparent 50%
      ),
      radial-gradient(
        circle at 80% 20%,
        rgba(139, 92, 246, 0.1) 0%,
        transparent 50%
      );
    pointer-events: none;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem 2rem 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 3rem;
    position: relative;
    z-index: 1;
  }

  .footer-section h3 {
    color: white;
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-section p {
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-weight: 500;
    padding: 0.5rem 0;
    border-bottom: 2px solid transparent;
    transition: all 0.3s ease;
    font-size: 0.9rem;
  }

  .footer-links a:hover {
    color: #8b5cf6;
    border-bottom-color: #8b5cf6;
  }

  .tech-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tech-list span {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9rem;
    padding: 0.5rem 0;
    border-left: 2px solid rgba(139, 92, 246, 0.3);
    padding-left: 1rem;
    transition: all 0.3s ease;
  }

  .tech-list span:hover {
    border-left-color: #8b5cf6;
    color: white;
    transform: translateX(4px);
  }

  .footer-social {
    margin-top: 1rem;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.2);
    position: relative;
    z-index: 1;
  }

  .footer-bottom-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-bottom p {
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    font-size: 0.9rem;
  }

  .footer-tagline {
    font-style: italic;
    color: rgba(139, 92, 246, 0.8) !important;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .footer-content {
      padding: 2.5rem 1rem 1rem 1rem;
      gap: 2rem;
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer-section h3 {
      font-size: 1.2rem;
      margin-bottom: 1rem;
    }

    .footer-section p {
      font-size: 0.9rem;
    }

    .footer-links {
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .footer-links a {
      font-size: 0.85rem;
    }

    .tech-list {
      align-items: center;
    }

    .tech-list span {
      font-size: 0.85rem;
      text-align: center;
      border-left: none;
      border-bottom: 2px solid rgba(139, 92, 246, 0.3);
      padding-left: 0;
      padding-bottom: 0.5rem;
    }

    .tech-list span:hover {
      border-left: none;
      border-bottom-color: #8b5cf6;
      transform: translateY(-2px);
    }

    .footer-bottom-content {
      flex-direction: column;
      text-align: center;
      padding: 1.5rem 1rem;
      gap: 0.5rem;
    }

    .footer-social {
      margin-top: 1.5rem;
    }

    .footer-social :global(.social-links) {
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .footer-content {
      padding: 2rem 0.5rem 1rem 0.5rem;
      gap: 1.5rem;
    }

    .footer-section {
      padding: 0 0.5rem;
    }

    .footer-section h3 {
      font-size: 1.1rem;
    }

    .footer-section p {
      font-size: 0.85rem;
    }

    .footer-links {
      gap: 0.75rem;
    }

    .footer-links a {
      font-size: 0.8rem;
      padding: 0.25rem 0;
    }

    .tech-list span {
      font-size: 0.8rem;
    }

    .footer-bottom-content {
      padding: 1rem 0.5rem;
    }

    .footer-bottom p {
      font-size: 0.8rem;
    }
  }
</style>
